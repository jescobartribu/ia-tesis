<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="voice_to_text.VoiceSystray">
        <!-- <div class="o_voice_systray_item px-2" style="cursor: pointer;" t-on-click="_onClick">
            <i class="fa fa-microphone fa-lg"/>
        </div> -->
        <div t-on-click="_onClick" 
            t-attf-class="o_voice_systray_item px-2 #{voiceState.isListening ? 'mic-listening' : ''}">
            <i class="fa fa-microphone fa-lg"/>
        </div>
    </t>

    <t t-name="voice_to_text.AssistantDialog">
        <Dialog title="props.title" size="'sm'">
            <div class="text-center p-4">
                <div t-if="props.transcript.isListening" 
                     t-attf-class="voice-visualizer mb-4 #{props.transcript.isPaused ? 'paused' : ''}">
                    <div class="bar"></div>
                    <div class="bar"></div>
                    <div class="bar"></div>
                    <div class="bar"></div>
                    <div class="bar"></div>
                </div>

                <div class="content-fade-in">
                    <span class="badge rounded-pill bg-light text-primary mb-2">Irene AI</span>
                    
                    <div class="transcript-box mb-4">
                        <small class="text-uppercase text-muted fw-bold d-block mb-1" style="font-size: 0.7rem;">Escuchando</small>
                        <p class="fs-5 fw-light italic">
                            "<t t-esc="props.transcript.transcript"/>"
                        </p>
                    </div>

                    <div t-if="props.transcript.answer" class="answer-box p-3 bg-faded rounded-3 border-start border-primary border-4">
                        <small class="text-uppercase text-primary fw-bold d-block mb-1" style="font-size: 0.7rem;">Respuesta</small>
                        <p class="fs-6 m-0">
                            <t t-esc="props.transcript.answer"/>
                        </p>
                    </div>
                </div>

                <div class="mt-4">
                    <button class="btn btn-outline-secondary rounded-pill px-4" t-on-click="props.close">Cerrar</button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>