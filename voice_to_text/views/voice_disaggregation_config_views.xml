<odoo>
    <record id="view_voice_disaggregation_config_form" model="ir.ui.view">
        <field name="name">voice.disaggregation.config.form</field>
        <field name="model">voice.disaggregation.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" placeholder="Ej: Registro de Citas"/>
                        <field name="model_id" options="{'no_create': True}"/>
                        <field name="model_name" />
                        <field name="field_id"/>
                        <field name="view_id"/>
                        <field name="inherit_id"/>
                    </group>
                    <notebook>
                        <page string="Configuración de Campos">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <!-- <field name="autocomplete_id" column_invisible="1"/>
                                    <field name="parent_model_id" options="{'no_create': True}" column_invisible="1"/>
                                    <field name="model_id" options="{'no_create': True}"/>
                                    <field name="field_id" options="{'no_create': True}"/> -->
                                    <field name="config_id" column_invisible="1"/>
                                    <field name="field_id" options="{'no_create': True}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_voice_disaggregation_config" model="ir.actions.act_window">
        <field name="name">Configuración de disgregación</field>
        <field name="res_model">voice.disaggregation.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_voice_disaggregation_config" name="Configuración de Disgregación" action="action_voice_disaggregation_config" parent="menu_voice_config_root"/>
</odoo>