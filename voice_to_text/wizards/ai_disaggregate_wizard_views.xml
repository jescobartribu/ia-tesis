<odoo>
    <record id="view_ia_disaggregate_wizard_form" model="ir.ui.view">
        <field name="name">ia.disaggregate.wizard.form</field>
        <field name="model">ia.disaggregate.wizard</field>
        <field name="arch" type="xml">
            <form string="Procesar con Irene IA">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Irene analizará el relato y llenará los campos configurados automáticamente.
                    </div>
                    <group>
                        <field name="config_id"/>
                        <field name="source_text" widget="text" style="max-height: 200px; overflow: auto;"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_disaggregate" string="✨ Iniciar Disgregación" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>