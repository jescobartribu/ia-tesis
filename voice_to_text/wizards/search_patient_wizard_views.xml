<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_search_patient_wizard_form" model="ir.ui.view">
        <field name="name">search.patient.wizard.form</field>
        <field name="model">search.patient.wizard</field>
        <field name="arch" type="xml">
            <form string="Consultar Cédula Externa">
                <h1 class="text-muted">Introduzca la cédula para buscar los datos en Mediq.</h1>
                <group>
                    <field name="vat" placeholder="V-12345678"/>
                </group>
                <footer>
                    <button string="Consultar y Sincronizar" name="action_search_external" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>